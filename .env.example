# LoopRR environment — documents every variable with EMPTY values.
# ZERO secrets in the repo. Real values live in Vercel (app) and the user's routine env (agent tokens).
# Keep this file in lockstep with the code (any new var lands here in the same commit).

# --- Supabase (LoopRR app) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-only — bypasses RLS; used ONLY inside the governed API. Never NEXT_PUBLIC_, never to a worker.
SUPABASE_SERVICE_ROLE_KEY=

# --- Governed API ---
LOOPRR_API_BASE=

# --- GitHub App (server-side git mediation; the real merge gate is branch protection) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Per-role agent tokens (verb-scoped) ---
# NOTE: in production these live in the USER's routine environment (their Claude app), not here.
# Listed for local/dev and documentation. Each maps to a role's allowed verbs in lib/agent-auth.ts.
LOOPRR_AGENT_TOKEN_PLANNER=
LOOPRR_AGENT_TOKEN_IMPLEMENTER=
LOOPRR_AGENT_TOKEN_REVIEWER=
LOOPRR_AGENT_TOKEN_SUPERVISOR=
